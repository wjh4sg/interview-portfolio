---
import { siteConfig } from "../config";
---

<section class="section shell" id="projects">
  <div class="section-heading">
    <p class="eyebrow">SELECTED WORK</p>
    <h2>两个项目，两条 AI 工程主线。</h2>
    <p>代码、版本和架构均可公开检查。每个项目都围绕真实工程问题设计，而不只是模型调用演示。</p>
  </div>

  <div class="project-list">
    {
      siteConfig.projects.map((project, index) => (
        <article class="project-card">
          <div class="project-index" aria-hidden="true">
            0{index + 1}
          </div>

          <div class="project-content">
            <div class="project-meta">
              <p>{project.eyebrow}</p>
              <a
                href={project.releaseUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Release {project.release}
              </a>
            </div>
            <h3>{project.name}</h3>
            <p class="project-summary">{project.summary}</p>

            <ul class="project-highlights">
              {project.highlights.map((highlight) => (
                <li>
                  <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="m5 12 4 4L19 6"></path>
                  </svg>
                  {highlight}
                </li>
              ))}
            </ul>

            <div class="tag-list" aria-label={`${project.name} 技术栈`}>
              {project.tags.map((tag) => <span>{tag}</span>)}
            </div>

            <div class="project-actions">
              <a
                class="button button-primary"
                href={project.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                查看源码
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M7 17 17 7M8 7h9v9"></path>
                </svg>
              </a>
              <span class="coming-soon">
                <span aria-hidden="true"></span>
                {project.status}
              </span>
            </div>
          </div>

          <figure class="architecture">
            <img
              src={project.architecture}
              alt={project.architectureAlt}
              loading="eager"
            />
            <figcaption>ARCHITECTURE / {project.release}</figcaption>
          </figure>
        </article>
      ))
    }
  </div>
</section>
