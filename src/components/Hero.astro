---
import { siteConfig } from "../config";
---

<section class="hero shell" id="top">
  <div class="hero-copy">
    <p class="availability">
      <span aria-hidden="true"></span>
      OPEN TO AI APPLICATION / BACKEND ROLES
    </p>
    <p class="hero-kicker">你好，我是 {siteConfig.name}。</p>
    <h1>
      把 AI 能力做成
      <span>可验证的工程系统。</span>
    </h1>
    <p class="hero-description">
      {siteConfig.title}。专注 Agent 工程、RAG 检索增强生成，以及可观测、可评测、可安全落地的后端实现。
    </p>

    <div class="hero-actions">
      <a class="button button-primary" href="#projects">
        查看项目
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </a>
      <a
        class="button button-secondary"
        href={siteConfig.resume}
        target="_blank"
        rel="noopener noreferrer"
      >
        下载简历
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14"></path>
        </svg>
      </a>
      <a
        class="text-link"
        href={siteConfig.github}
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M7 17 17 7M8 7h9v9"></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="hero-system" aria-label="工程关注点">
    <div class="system-topbar">
      <span></span><span></span><span></span>
      <p>system.profile</p>
    </div>
    <div class="system-body">
      <p><span>01</span> problem.definition</p>
      <p><span>02</span> controlled.execution</p>
      <p><span>03</span> retrieval.quality</p>
      <p><span>04</span> evidence.citation</p>
      <p><span>05</span> offline.evaluation</p>
      <div class="system-result">
        <span class="prompt">$</span>
        <strong>build → measure → iterate</strong>
        <span class="cursor" aria-hidden="true"></span>
      </div>
    </div>
    <div class="system-footer">
      <span>AGENT</span>
      <span>RAG</span>
      <span>BACKEND</span>
    </div>
  </div>
</section>
